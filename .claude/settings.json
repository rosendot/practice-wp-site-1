{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(composer install)",
      "Bash(composer require*)",
      "Bash(composer update*)",
      "Bash(php*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(cp*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /)*",
      "Bash(DROP TABLE*)",
      "Bash(DROP DATABASE*)"
    ]
  },
  "environment": {
    "WP_THEME_DIR": "web/app/themes/my-theme"
  }
}
